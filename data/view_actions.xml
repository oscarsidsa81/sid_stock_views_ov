<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="action_stock_picking_madrid_asignacion_linea" model="ir.actions.act_window">
            <field name="name">Madrid: Picking / Asignación por línea</field>
            <field name="res_model">stock.move</field>
            <field name="type">ir.actions.act_window</field>
            <!-- Modos disponibles (como en tu captura) -->
            <field name="view_mode">tree,form</field>
            <!-- Vista tree por defecto -->
            <field name="view_id" ref="view_stock_move_tree_ov"/>
            <field name="search_view_id" ref="view_stock_move_search_ov"/>
            <!-- Dominio -->
            <field name="domain" eval="[
                ('state', 'not in', ('done', 'cancel', 'draft')),
            ]"/>
            <!-- Contexto (si quieres agrupar por estado como se ve en muchas listas) -->
            <field name="context">{}</field>
            <!-- Opcional: límite -->
            <field name="limit">150</field>
        </record>

        <record id="action_stock_picking_madrid_entregas_devoluciones" model="ir.actions.act_window">
            <field name="name">Madrid: Entregas y Devoluciones</field>
            <field name="res_model">stock.picking</field>
            <field name="type">ir.actions.act_window</field>
            <!-- Modos disponibles (como en tu captura) -->
            <field name="view_mode">tree,form,calendar</field>
            <!-- Vista tree por defecto -->
            <field name="view_id" ref="view_stock_picking_tree_madrid_delivery_return"/>
            <!-- Dominio -->
            <field name="domain" eval="[
                ('state', 'in', ('waiting', 'confirmed', 'assigned')),
                ('picking_type_id', 'in', [
                    ref('stock.picking_type_out'),
                    ref('sid_stock_cfg.stock_picking_type__mad__incoming__seq8__returns__c1'),
                ])
            ]"/>
            <!-- Contexto (si quieres agrupar por estado como se ve en muchas listas) -->
            <field name="context">{'group_by': 'state'}</field>
            <!-- Opcional: límite -->
            <field name="limit">80</field>
        </record>

        <record id="action_stock_picking_madrid_picking_recepciones" model="ir.actions.act_window">
            <field name="name">Madrid: Picking y Recepciones</field>
            <field name="res_model">stock.picking</field>
            <field name="type">ir.actions.act_window</field>
            <!-- Modos disponibles (como en tu captura) -->
            <field name="view_mode">tree,form,calendar</field>
            <!-- Vista tree por defecto -->
            <field name="view_id" ref="view_stock_picking_tree_madrid_delivery_return"/>
            <!-- Dominio -->
            <field name="domain" eval="[
                ('state', 'in', ('waiting', 'confirmed', 'assigned')),
                ('picking_type_id', 'in', [
                    ref('sid_stock_cfg.stock_picking_type__mad__incoming__seq1__receipts__c1'),
                    ref('stock.picking_type_in'),
                    ref('sid_stock_cfg.stock_picking_type__mad__internal__seq3__picking_inventario__c1'),
                    ref('sid_stock_cfg.stock_picking_type__mad__internal__seq5__picking_cv__c1'),
                ])
            ]"/>
            <!-- Contexto (si quieres agrupar por estado como se ve en muchas listas) -->
            <field name="context">{'group_by': 'state'}</field>
            <!-- Opcional: límite -->
            <field name="limit">80</field>
        </record>

        <record id="action_stock_picking_ptllno_entregas_devoluciones" model="ir.actions.act_window">
            <field name="name">Puertollano: Picking y Recepciones</field>
            <field name="res_model">stock.picking</field>
            <field name="type">ir.actions.act_window</field>
            <!-- Modos disponibles (como en tu captura) -->
            <field name="view_mode">tree,form,calendar</field>
            <!-- Vista tree por defecto -->
            <field name="view_id" ref="view_stock_picking_tree_madrid_delivery_return"/>
            <!-- Dominio -->
            <field name="domain" eval="[
                ('state', 'in', ('waiting', 'confirmed', 'assigned')),
                ('sale_id.team_id.id','=',ref('sales_team.team_sales_department_ptllno')),
                ('picking_type_id', 'in', [
                    ref('sid_stock_cfg.stock_picking_type__ptllo__outgoing__seq9__expediciones__c1'),
                    ref('sid_stock_cfg.stock_picking_type__ptllo__incoming__seq10__devoluciones__c1'),
                ])
            ]"/>
            <!-- Contexto (si quieres agrupar por estado como se ve en muchas listas) -->
            <field name="context">{'group_by': 'state'}</field>
            <!-- Opcional: límite -->
            <field name="limit">80</field>
        </record>

        <record id="action_stock_picking_certificates" model="ir.actions.act_window">
            <field name="name">Certificados</field>
            <field name="res_model">stock.picking</field>
            <field name="type">ir.actions.act_window</field>
            <!-- Modos disponibles (como en tu captura) -->
            <field name="view_mode">tree,form</field>
            <!-- Vista tree por defecto -->
            <field name="view_id" ref="view_stock_picking_tree_certificates"/>
            <!-- Dominio -->
            <field name="domain" eval="[
                ('state', 'in', ('waiting', 'confirmed', 'assigned')),
                ('sale_id.team_id.id','=',ref('sales_team.team_sales_department_ptllno')),
                ('picking_type_id', 'in', [
                    ref('sid_stock_cfg.stock_picking_type__ptllo__outgoing__seq9__expediciones__c1'),
                    ref('sid_stock_cfg.stock_picking_type__ptllo__incoming__seq10__devoluciones__c1'),
                ])
            ]"/>
            <!-- Contexto (si quieres agrupar por estado como se ve en muchas listas) -->
            <field name="context">{'group_by': 'state'}</field>
            <!-- Opcional: límite -->
            <field name="limit">80</field>
        </record>

        <record id="action_stock_quant_devoluciones_errores" model="ir.actions.act_window">
            <field name="name">Devoluciones o errores</field>
            <field name="res_model">stock.quant</field>
            <field name="type">ir.actions.act_window</field>
            <!-- Modos disponibles (como en tu captura) -->
            <field name="view_mode">tree,form</field>
            <!-- Vista tree por defecto -->
            <!-- Dominio -->
            <field name="domain" eval="[
                ('package_id', '=', False),
                ('location_id.usage', 'in', ['internal', 'transit']),
                ('reserved_quantity', '=', 0),
                ('location_id.name', 'not ilike', 'val'),
                ('quantity', '&gt;', 0)
            ]"/>
            <!-- Contexto (si quieres agrupar por estado como se ve en muchas listas) -->
            <field name="context">{}</field>
            <!-- Opcional: límite -->
            <field name="limit">80</field>
        </record>

        <!-- Menú padre: Asignación (hijo de stock.menu_stock_root) -->
        <menuitem id="menu_asignacion_root"
                  name="Asignación"
                  parent="stock.menu_stock_root"
                  sequence="10"/>

        <!-- 5 hijos como en la imagen (aún sin acciones) -->
        <menuitem id="menu_madrid_picking_asignacion_por_linea"
                  name="Madrid: Picking / Asignación por línea"
                  parent="menu_asignacion_root"
                  action="action_stock_picking_madrid_asignacion_linea"
                  sequence="10"/>

        <menuitem id="menu_madrid_picking_y_recepciones"
                  name="Madrid: Picking y Recepciones"
                  parent="menu_asignacion_root"
                  action="action_stock_picking_madrid_picking_recepciones"
                  sequence="20"/>

        <menuitem id="menu_madrid_entregas_y_devoluciones"
                  name="Madrid: Entregas y Devoluciones"
                  parent="menu_asignacion_root"
                  action="action_stock_picking_madrid_entregas_devoluciones"
                  sequence="30"/>

        <menuitem id="menu_puertollano_entregas_y_devoluciones"
                  name="Puertollano: Entregas y Devoluciones"
                  parent="menu_asignacion_root"
                  action="action_stock_picking_ptllno_entregas_devoluciones"
                  sequence="40"/>

        <menuitem id="menu_certificados"
                  name="Certificados"
                  parent="menu_asignacion_root"
                  action="action_stock_picking_certificates"
                  sequence="50"/>

        <menuitem id="dev_and_err"
                  name="Devoluciones y Errores"
                  parent="stock.menu_warehouse_report"
                  action="action_stock_quant_devoluciones_errores"
                  sequence="6"/>
    </data>
</odoo>