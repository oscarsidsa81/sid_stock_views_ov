<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_picking_form_ov" model="ir.ui.view">
            <field name="name">stock.picking.sid_form.mod</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="priority">1001</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='picking_type_id']" position="before">
                    <field name="sid_asignado" string="Asignado a: "/>
                </xpath>
                <xpath expr="//field[@name='partner_id']" position="after">
                    <field name="sid_cliente" readonly="1"/>
                    <field name="pedido_cliente" readonly="1"/>
                </xpath>
                <xpath expr="//field[@name='partner_id']" position="attributes">
                    <attribute name="attrs">{'readonly':[('state','in',['cancel'])]}</attribute>
                </xpath>
                <xpath expr="//button[@name='action_assign']" position="attributes">
                    <attribute name="attrs">{'invisible': [('state', '!=', 'done')]}</attribute>
                </xpath>
                <xpath expr="//field[@name='relleno']" position="attributes">
                    <attribute name="string">Mostrar nº de tubos</attribute>
                </xpath>
                <xpath expr="//field[@name='backorder_id']" position="before">
                    <field name="qty_done_pct" nolabel="1" string="Resumen"
                           style="vertical-align:middle;background-color:grey;font-size:15px;color:yellow;"/>
                </xpath>
                <xpath expr="//field[@name='qty_done_pct']" position="before">
                    <field name="sid_completado" string="Completado: "/>
                </xpath>

                <xpath expr="//notebook[1]//page[2]//tree[1]" position="attributes">
                    <attribute name="decoration-success"></attribute>
                    <attribute name="decoration-danger"></attribute>
                    <attribute name="decoration-bf">1</attribute>
                    <attribute name="decoration-danger">po_comments == 'Cancelado****' or comments in ['Cancelado sólo en la venta****', 'Cancelado**** Cancelado sólo en la venta****'] or product_uom_qty &lt;= 0</attribute>
                    <attribute name="decoration-success">state != 'done' and product_uom_qty &gt; 0 and quantity_done &gt;= product_uom_qty</attribute>
                    <attribute name="decoration-muted">po_comments != 'Cancelado****' and comments not in ['Cancelado sólo en la venta****', 'Cancelado**** Cancelado sólo en la venta****'] and state != 'done' and product_uom_qty &gt; 0 and quantity_done &lt; product_uom_qty</attribute>
                    <attribute name="decoration-it">state == 'done'</attribute>
                </xpath>

                <xpath expr="//notebook[1]//page[2]//tree[1]//field[@name='product_id']" position="after">
                    <field name='family' optional="show" class="text-center"/>
                </xpath>
                <xpath expr="//sheet[1]" position="attributes">
                    <attribute name="style">min-width: 100%;</attribute>
                </xpath>
                <xpath expr="//notebook[1]//page[2]//tree[1]//field[@name='item']" position="attributes">
                    <attribute name="style">background-color:grey;text-align:center;color:white;</attribute>
                </xpath>
                <xpath expr="//notebook[1]//page[2]//tree[1]//field[@name='comments']" position="attributes">
                    <attribute name="style">background-color:grey;text-align:center;color:yellow;</attribute>
                    <attribute name="widget">text</attribute>
                </xpath>
                <xpath expr="//notebook[1]//page[2]//tree[1]//field[@name='todo']" position="attributes">
                    <attribute name="string">Actividad</attribute>
                    <attribute name="widget">boolean_toggle</attribute>
                </xpath>
                <xpath expr="//notebook[1]//page[2]//tree[1]//field[@name='description_picking']"
                       position="attributes">
                    <attribute name="optional">show</attribute>
                    <attribute name="readonly">1</attribute>
                </xpath>
                <xpath expr="//field[@name='shipping_weight']" position="attributes">
                    <attribute name="readonly">0</attribute>
                </xpath>
                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[@name='operations']/field[@name='move_ids_without_package']/tree[1]"
                       position="attributes">
                    <attribute name="default_order">id</attribute>
                </xpath>
                <xpath expr="//button[@name='action_show_details']" position="after">
                    <field name="id" string="Orden" optional="show" widget="handle"/>
                </xpath>
                <xpath expr="//notebook[1]//page[2]//tree[1]//field[@name='po_comments']" position="attributes">
                    <attribute name='invisible'>1</attribute>
                </xpath>
            </field>
        </record>

        <!-- Stock Picking: Tree -->
<record id="view_stock_picking_tree_madrid_delivery_return" model="ir.ui.view">
    <field name="name">stock.picking.tree.madrid.delivery.return</field>
    <field name="model">stock.picking</field>
    <field name="type">tree</field>
    <field name="arch" type="xml">
        <tree string="Picking list"
              multi_edit="1"
              default_order="scheduled_date asc, priority desc, name asc"
              delete="0">

            <field name="priority" optional="show" widget="priority" nolabel="1"/>
            <field name="qty_done_pct" optional="show" widget="percentpie" nolabel="1" string="        " class="text-center"/>
            <field name="sid_scope_summary" optional="show" class="text-center"/>
            <field name="sid_enviar" optional="show" string="Enviar" class="text-center" widget="boolean_toggle"/>
            <field name="sid_completado" optional="show" string="Comp." class="text-center" widget="boolean_toggle"/>

            <button class="oe_inline"
                    icon="fa-reply"
                    name="%(sid_stock_views_ov.sid_act_server_picking_origen)d"
                    type="action"
                    help="Albaranes origen"/>

            <button class="oe_inline"
                    icon="fa-share"
                    name="%(sid_stock_views_ov.sid_act_server_picking_destino)d"
                    type="action"
                    help="Albaranes destino"/>

            <field name="sid_asignado" optional="show" widget="many2one_avatar_user" class="text-center"/>

            <field name="group_id" string="Pedido" optional="show" class="text-center" decoration-bf="1"/>
            <field name="name" decoration-bf="1"/>
            <field name="location_id" options="{'no_create': True}" string="From"
                   groups="stock.group_stock_multi_locations" optional="hide"/>
            <field name="location_dest_id" options="{'no_create': True}" string="To"
                   groups="stock.group_stock_multi_locations" optional="hide"/>
            <field name="partner_id" string="Dirección" optional="show"/>
            <field name="sid_cliente" string="Cliente" optional="show"/>

            <field name="is_signed" string="Signed" optional="hide" groups="stock.group_stock_sign_delivery"/>
            <field name="user_id" optional="hide" widget="many2one_avatar_user"/>

            <field name="scheduled_date" optional="show" class="text-center"
                   widget="remaining_days"
                   attrs="{'invisible':[('state', 'in', ('done', 'cancel'))]}"/>

            <field name="activity_ids" widget="list_activity"/>
            <field name="activity_user_id" optional="show" string="Usuario" widget="many2one_avatar_user"/>
            <field name="my_activity_date_deadline" string="Deadline" widget="remaining_days"
                   options="{'allow_order': '1'}"/>

            <field name="picking_type_code" invisible="1"/>
            <field name="products_availability_state" invisible="1" options="{'lazy': true}"/>
            <field name="products_availability" options="{'lazy': true}" optional="hide"
                   attrs="{'invisible': ['|', ('picking_type_code', '!=', 'outgoing'), ('state', 'not in', ['confirmed', 'waiting', 'assigned'])]}"
                   decoration-success="state == 'assigned' or products_availability_state == 'available'"
                   decoration-warning="state != 'assigned' and products_availability_state in ('expected', 'available')"
                   decoration-danger="state != 'assigned' and products_availability_state == 'late'"/>

            <field name="date_deadline" optional="hide" widget="remaining_days"
                   attrs="{'invisible':[('state', 'in', ('done', 'cancel'))]}"/>
            <field name="date_done" string="Effective Date" optional="hide"/>
            <field name="origin" optional="show" readonly="1"/>
            <field name="carrier_id" optional="show" string="Transportista"/>
            <field name="weight" optional="show" class="text-center"/>
            <field name="shipping_weight" optional="show" class="text-center"/>
            <field name="backorder_id" optional="show"/>
            <field name="picking_type_id" optional="hide"/>
            <field name="company_id" groups="base.group_multi_company" optional="hide"/>

            <field name="state" optional="show" widget="badge"
                   decoration-success="state == 'done'"
                   decoration-info="state not in ('done', 'cancel', 'draft')"
                   decoration-muted="state == 'draft'"/>

            <field name="activity_exception_decoration" widget="activity_exception"/>
            <field name="json_popover" nolabel="1" widget="stock_rescheduling_popover"
                   attrs="{'invisible': [('json_popover', '=', False)]}"/>

        </tree>
    </field>
</record>
        <!--        VISTA BASE DE STOCK MOVES      -->

        <record id="view_stock_move_tree_ov" model="ir.ui.view">
            <field name="name">stock.move.tree_ov</field>
            <field name="model">stock.move</field>
            <field name="priority">12</field>
            <field name="type">tree</field>
            <field name="arch" type="xml">
                <tree string="Moves" create="0" multi_edit="1" edit="1"
                      decoration-danger="(state not in ('cancel','done')) and date &lt; current_date">
                    <field name="date" groups="base.group_no_one"/>
                    <field name="reference"/>
                    <field name="group_id" optional="show" string="Pedido" readonly="1"/>
                    <field name="todo" string="Act" widget="boolean_toggle" optional="show"/>
                    <field name="item" readonly="1"/>
                    <field name="family" readonly="1"/>
                    <field name="picking_type_id" invisible="1"/>
                    <field name="product_id" readonly="1"/>
                    <field name="description_picking" readonly="1"/>
                    <field name="location_id" options="{'no_create': True}" string="From"/>
                    <field name="location_dest_id" options="{'no_create': True}" string="To"/>
                    <field name="product_packaging_id" optional="hide" groups="product.group_stock_packaging"/>
                    <field name="product_uom_qty"/>
                    <field name="product_uom" options="{'no_open': True, 'no_create': True}"
                           string="Unit of Measure" groups="uom.group_uom"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                    <field name="state" widget="badge"
                           decoration-success="state == 'done'"
                           decoration-info="state not in ('done', 'cancel')"/>
                </tree>
            </field>
        </record>

        <record id="view_stock_move_search_ov" model="ir.ui.view">
            <field name="name">stock.move.search_ov</field>
            <field name="model">stock.move</field>
            <field name="type">search</field>
            <field name="priority">4</field>
            <field name="arch" type="xml">
                <search string="Stock Moves">
                    <field name="origin"
                           filter_domain="['|', '|', ('origin', 'ilike', self), ('name', 'ilike', self), ('picking_id', 'ilike', self)]"
                           string="Reference"/>
                    <field name="product_id"/>
                    <field name="name" string="Location"
                           filter_domain="['|',('location_id', 'ilike', self),('location_dest_id', 'ilike', self)]"/>
                    <field name="partner_id" string="Partner"
                           filter_domain="[('picking_id.partner_id', 'child_of', self)]"/>
                    <filter string="Con Actividades" name="actividades" domain="[('activity_ids','!=',False)]"
                            help="Ver líneas con actividades de Venta"/>
                    <filter string="Ready" name="ready" domain="[('state','=','assigned')]"
                            help="Stock moves that are Available (Ready to process)"/>
                    <filter string="To Do" name="future" domain="[('state','in',('assigned','confirmed','waiting'))]"
                            help="Stock moves that are Confirmed, Available or Waiting"/>
                    <filter string="Done" name="done" domain="[('state','=','done')]"
                            help="Stock moves that have been processed"/>
                    <separator/>
                    <filter string="Incoming" name="incoming"
                            domain="[('location_id.usage', 'not in', ('internal', 'transit')), ('location_dest_id.usage', 'in', ('internal', 'transit'))]"/>
                    <filter string="Outgoing" name="outgoing"
                            domain="[('location_id.usage', 'in', ('internal', 'transit')), ('location_dest_id.usage', 'not in', ('internal', 'transit'))]"/>
                    <filter string="Inventory" name="inventory" domain="[('is_inventory', '=', True)]"/>
                    <separator/>
                    <filter string="Date" name="today" date="date" help="Scheduled or processing date"/>
                    <group expand="0" string="Group By">
                        <filter string="Product" name="by_product" domain="[]" context="{'group_by': 'product_id'}"/>
                        <filter string="Pedido" name="by_group" domain="[]" context="{'group_by': 'group_id'}"/>
                        <filter string="Picking" name="groupby_picking_id" domain="[]"
                                context="{'group_by': 'picking_id'}"/>
                        <filter string="Source Location" name="groupby_location_id" domain="[]"
                                context="{'group_by': 'location_id'}" groups="stock.group_stock_multi_locations"/>
                        <filter string="Destination Location" name="groupby_dest_location_id" domain="[]"
                                context="{'group_by': 'location_dest_id'}" groups="stock.group_stock_multi_locations"/>
                        <filter string="Status" name="status" domain="[]" context="{'group_by': 'state'}"/>
                        <filter string="Creation Date" name="groupby_create_date" domain="[]"
                                context="{'group_by': 'create_date'}" groups="base.group_no_one"/>
                        <filter string="Scheduled Date" name="groupby_date" domain="[]" context="{'group_by': 'date'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="view_stock_picking_search_ov" model="ir.ui.view">
            <field name="name">stock.picking.search_ov</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_internal_search"/>
            <field name="type">search</field>
            <field name="priority">18</field>
            <field name="arch" type="xml">
                <xpath expr="//search[1]/field[@name='name']" position="after">
                    <field name="sid_cliente" string="Cliente"/>
                    <field name="group_id" string="Pedido - Grupo"/>
                </xpath>
                <xpath expr="//filter[@name='status']" position="before">
                    <filter name="sid_grupo_abastecimiento" string="Pedido - Grupo" context="{'group_by': 'group_id'}"/>
                </xpath>
                <search>
                    <searchpanel>
                        <field name="carrier_id" enable_counters="1" select="multi"/>
                        <field name="partner_id" enable_counters="1" select="multi"/>
                    </searchpanel>
                </search>
            </field>
        </record>

        <record id="view_stock_picking_tree_certificates" model="ir.ui.view">
            <field name="name">stock.picking.tree.certificates</field>
            <field name="model">stock.picking</field>
            <field name="type">tree</field>
            <field name="arch" type="xml">
                <tree string="Picking list" js_class="lazy_column_list" multi_edit="0" sample="1">
                    <header>
                        <button name="do_unreserve" type="object" string="Unreserve"/>
                        <button name="action_assign" type="object" string="Check Availability"/>
                    </header>
                    <field name="priority" optional="show" widget="priority" nolabel="1"/>
                    <field name="name" decoration-bf="1"/>
                    <field name="location_id" options="{'no_create': True}" string="From"
                           groups="stock.group_stock_multi_locations" optional="show"/>
                    <field name="location_dest_id" options="{'no_create': True}" string="To"
                           groups="stock.group_stock_multi_locations" optional="show"/>
                    <field name="partner_id" optional="show"/>
                    <field name="is_signed" string="Signed" optional="hide" groups="stock.group_stock_sign_delivery"/>
                    <field name="user_id" optional="hide" widget="many2one_avatar_user"/>
                    <field name="scheduled_date" optional="show" widget="remaining_days"
                           attrs="{'invisible':[('state', 'in', ('done', 'cancel'))]}"/>
                    <field name="picking_type_code" invisible="1"/>
                    <field name="products_availability_state" invisible="1" options="{&quot;lazy&quot;: true}"/>
                    <field name="products_availability" options="{&quot;lazy&quot;: true}" optional="hide"
                           attrs="{'invisible': ['|', ('picking_type_code', '!=', 'outgoing'), ('state', 'not in', ['confirmed', 'waiting', 'assigned'])]}"
                           decoration-success="state == 'assigned' or products_availability_state == 'available'"
                           decoration-warning="state != 'assigned' and products_availability_state in ('expected', 'available')"
                           decoration-danger="state != 'assigned' and products_availability_state == 'late'"/>
                    <field name="date_deadline" optional="hide" widget="remaining_days"
                           attrs="{'invisible':[('state', 'in', ('done', 'cancel'))]}"/>
                    <field name="date_done" string="Effective Date" optional="hide"/>
                    <field name="origin" optional="show"/>
                    <field name="backorder_id" optional="hide"/>
                    <field name="picking_type_id" optional="hide"/>
                    <field name="company_id" groups="base.group_multi_company" optional="show"/>
                    <field name="state" optional="show" widget="badge" decoration-success="state == 'done'"
                           decoration-info="state not in ('done', 'cancel', 'draft')"
                           decoration-muted="state == 'draft'"/>
                    <field name="activity_exception_decoration" widget="activity_exception"/>
                    <field name="json_popover" nolabel="1" widget="stock_rescheduling_popover"
                           attrs="{'invisible': [('json_popover', '=', False)]}"/>
                </tree>
            </field>
        </record>

    </data>
</odoo>